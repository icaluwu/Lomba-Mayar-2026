# ──────────────────────────────────────────────
#  KamusNers — Environment Variables Template
#  Copy this file to .env and fill in the values
#  cp .env.example .env
# ──────────────────────────────────────────────

# ── Mayar.id Integration ──────────────────────
# Your Mayar public API key (safe to use client-side)
# Get it from: https://mayar.id/app/settings/api
PUBLIC_MAYAR_API_KEY=your_mayar_public_api_key_here

# Your Mayar Webhook Secret (SERVER-SIDE ONLY — never expose to client!)
# Get it from: https://mayar.id/app/settings/webhook
MAYAR_WEBHOOK_SECRET=your_mayar_webhook_secret_here

# ── Site URL (only needed for production) ─────
# Used for Canonical URLs and Open Graph tags
# Example: https://kamusners.vercel.app
# SITE_URL=https://kamusners.vercel.app
