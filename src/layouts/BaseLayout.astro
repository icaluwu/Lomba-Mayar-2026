---
interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'KamusNers - Platform Kelas Online untuk Perawat',
  description = 'KamusNers adalah platform kelas online premium untuk perawat Indonesia. Tingkatkan kompetensi keperawatan Anda bersama pengajar berpengalaman.',
  image = '/og-image.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://kamusners.vercel.app');
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Social -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:locale" content="id_ID" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <title>{title}</title>

    <!-- AOS CSS -->
    <link rel="stylesheet" href="https://unpkg.com/aos@2.3.4/dist/aos.css" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="shortcut icon" href="/favicon.png" />
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Navbar -->
    <slot name="navbar" />

    <!-- Page Content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <slot name="footer" />

    <!-- WhatsApp FAB -->
    <slot name="fab" />

    <!-- AOS Init via npm package (reliable, no CDN race conditions) -->
    <script>
      import AOS from 'aos';
      AOS.init({
        duration: 700,
        easing: 'ease-out-cubic',
        once: true,
        offset: 60,
      });
    </script>
  </body>
</html>
