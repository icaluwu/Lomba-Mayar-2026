---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

export const prerender = true;
---

<BaseLayout
  title="Hubungi Kami - KamusNers"
  description="Hubungi tim KamusNers untuk pertanyaan seputar kelas, pembayaran, atau informasi lainnya. Siap melayani Anda."
>
  <Navbar slot="navbar" />
  <Footer slot="footer" />
  <WhatsAppButton slot="fab" />

  <!-- Page Header -->
  <section class="bg-primary-900 pt-28 pb-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="badge-teal mb-4 inline-block" data-aos="fade-up">📬 Hubungi Kami</span>
      <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4" data-aos="fade-up" data-aos-delay="100">
        Ada Pertanyaan? <span class="gradient-text">Kami Siap Membantu</span>
      </h1>
      <p class="text-white/60 text-lg" data-aos="fade-up" data-aos-delay="200">
        Hubungi kami melalui WhatsApp, email, atau isi form di bawah ini. Tim kami akan merespons dalam 1×24 jam.
      </p>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-start">

        <!-- Contact Info -->
        <div data-aos="fade-right">
          <h2 class="text-2xl font-bold text-primary-800 mb-8">Informasi Kontak</h2>
          <div class="space-y-5">
            <!-- WhatsApp -->
            <a
              href="https://wa.me/6287896542511?text=Halo%20KamusNers%2C%20saya%20ingin%20bertanya%20tentang%20kelas%20online"
              target="_blank"
              rel="noopener"
              class="flex items-center gap-5 p-5 bg-white rounded-2xl shadow-card hover:shadow-card-hover hover:-translate-y-0.5 transition-all group"
            >
              <div class="w-12 h-12 rounded-xl bg-green-100 group-hover:bg-green-500 flex items-center justify-center text-green-500 group-hover:text-white transition-colors shrink-0">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
              </div>
              <div>
                <div class="font-bold text-gray-800">WhatsApp</div>
                <div class="text-gray-500 text-sm">+62 878-9654-2511</div>
                <div class="text-teal-600 text-xs font-medium mt-1">Respons paling cepat ↗</div>
              </div>
            </a>

            <!-- Email -->
            <a
              href="mailto:admin@kamusners.id"
              class="flex items-center gap-5 p-5 bg-white rounded-2xl shadow-card hover:shadow-card-hover hover:-translate-y-0.5 transition-all group"
            >
              <div class="w-12 h-12 rounded-xl bg-primary-50 group-hover:bg-primary-600 flex items-center justify-center text-primary-600 group-hover:text-white transition-colors shrink-0">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="2" y="4" width="20" height="16" rx="2"/>
                  <path d="m22 7-10 7L2 7"/>
                </svg>
              </div>
              <div>
                <div class="font-bold text-gray-800">Email</div>
                <div class="text-gray-500 text-sm">admin@kamusners.id</div>
                <div class="text-gray-400 text-xs mt-1">Respons dalam 1×24 jam</div>
              </div>
            </a>

            <!-- Hours -->
            <div class="flex items-center gap-5 p-5 bg-white rounded-2xl shadow-card">
              <div class="w-12 h-12 rounded-xl bg-teal-50 flex items-center justify-center text-teal-600 shrink-0">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                </svg>
              </div>
              <div>
                <div class="font-bold text-gray-800">Jam Operasional</div>
                <div class="text-gray-500 text-sm">Senin – Sabtu: 08.00 – 17.00 WIB</div>
                <div class="text-gray-400 text-xs mt-1">Minggu & Hari Libur: Tutup</div>
              </div>
            </div>
          </div>

          <!-- FAQ highlight -->
          <div class="mt-8 bg-primary-50 rounded-2xl p-5 border border-primary-100">
            <h3 class="font-bold text-primary-800 mb-3">❓ Pertanyaan Umum</h3>
            <ul class="space-y-2 text-sm text-gray-600">
              <li>• Bagaimana cara mengakses kelas setelah bayar?</li>
              <li>• Apakah ada masa berlaku akses kelas?</li>
              <li>• Sertifikat apakah sudah terakreditasi?</li>
              <li>• Bagaimana jika ada kendala teknis?</li>
            </ul>
            <a href="https://wa.me/6287896542511" target="_blank" rel="noopener" class="btn-primary text-sm mt-4 py-2 px-4 inline-flex">
              Tanya Langsung →
            </a>
          </div>
        </div>

        <!-- Contact Form -->
        <div data-aos="fade-left">
          <div class="bg-white rounded-2xl shadow-card p-8">
            <h2 class="text-2xl font-bold text-primary-800 mb-6">Kirim Pesan</h2>
            <form
              id="contact-form"
              action="mailto:admin@kamusners.id"
              method="post"
              enctype="text/plain"
              class="space-y-5"
            >
              <div>
                <label for="name" class="block text-sm font-semibold text-gray-700 mb-1.5">Nama Lengkap <span class="text-red-500">*</span></label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  placeholder="Ns. Nama Anda, S.Kep."
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-semibold text-gray-700 mb-1.5">Email <span class="text-red-500">*</span></label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="email@contoh.com"
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm"
                />
              </div>
              <div>
                <label for="subject" class="block text-sm font-semibold text-gray-700 mb-1.5">Topik</label>
                <select
                  id="subject"
                  name="subject"
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm bg-white"
                >
                  <option value="">Pilih topik...</option>
                  <option value="kelas">Informasi Kelas</option>
                  <option value="pembayaran">Pembayaran & Invoice</option>
                  <option value="teknis">Kendala Teknis</option>
                  <option value="sertifikat">Sertifikat</option>
                  <option value="lainnya">Lainnya</option>
                </select>
              </div>
              <div>
                <label for="message" class="block text-sm font-semibold text-gray-700 mb-1.5">Pesan <span class="text-red-500">*</span></label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows="5"
                  placeholder="Tuliskan pertanyaan atau pesan Anda di sini..."
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-sm resize-none"
                ></textarea>
              </div>
              <button
                type="submit"
                class="w-full btn-primary justify-center py-3.5 text-base"
              >
                Kirim Pesan
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="22" y1="2" x2="11" y2="13"/>
                  <polygon points="22 2 15 22 11 13 2 9 22 2"/>
                </svg>
              </button>
              <p class="text-xs text-gray-400 text-center">
                Atau hubungi langsung via <a href="https://wa.me/6287896542511" class="text-teal-600 font-medium hover:underline">WhatsApp</a> untuk respons lebih cepat.
              </p>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
