---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import CourseCard from '../components/CourseCard.astro';

export const prerender = true;

const featuredCourses = [
  {
    title: 'Keperawatan Medikal Bedah',
    description: 'Kuasai penanganan pasien medikal-bedah secara komprehensif, dari pre-op hingga post-op dan pengelolaan komplikasi.',
    price: 299000,
    originalPrice: 499000,
    checkoutUrl: 'https://mayar.id/checkout/medikal-bedah',
    badge: '🔥 Terlaris',
    badgeType: 'popular' as const,
    duration: '10 minggu',
    level: 'Intermediate',
    students: '500+',
    image: '/courses/medikal-bedah.png',
  },
  {
    title: 'Keperawatan Gawat Darurat (KGD)',
    description: 'Pelajari triage, resusitasi, dan manajemen gawat darurat untuk kehidupan nyata di IGD.',
    price: 249000,
    originalPrice: 399000,
    checkoutUrl: 'https://mayar.id/checkout/kgd',
    badge: 'Baru',
    badgeType: 'teal' as const,
    duration: '8 minggu',
    level: 'Advanced',
    students: '300+',
    image: '/courses/kgd.png',
  },
  {
    title: 'Keperawatan Maternitas',
    description: 'Asuhan keperawatan ibu hamil, persalinan, nifas, dan bayi baru lahir berbasis evidence-based practice.',
    price: 229000,
    originalPrice: 349000,
    checkoutUrl: 'https://mayar.id/checkout/maternitas',
    badge: 'EBP',
    badgeType: 'primary' as const,
    duration: '8 minggu',
    level: 'Semua Level',
    students: '400+',
    image: '/courses/maternitas.png',
  },
];

const features = [
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5-10-5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>`,
    title: 'Kurikulum Berbasis Kompetensi',
    desc: 'Dirancang oleh perawat profesional mengacu pada standar SKKNI dan kurikulum Ners terkini.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
    title: 'Belajar Kapan Saja & Di Mana Saja',
    desc: 'Akses materi video, modul PDF, dan kuis interaktif 24/7 dari perangkat apa pun.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    title: 'Komunitas Perawat Aktif',
    desc: 'Bergabung dengan ribuan perawat Indonesia, diskusi kasus, dan saling berbagi pengalaman.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
    title: 'Sertifikat Resmi',
    desc: 'Dapatkan sertifikat kelulusan digital yang dapat dilampirkan di portofolio dan LinkedIn.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    title: 'Live Session Interaktif',
    desc: 'Sesi live Q&A rutin bersama instruktur berpengalaman untuk membahas kasus dan pertanyaan.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Uji Kompetensi Simulasi',
    desc: 'Latihan soal UKMPPD gaya terbaru dengan pembahasan mendalam dari instruktur kami.',
  },
];

const testimonials = [
  {
    name: 'Ns. Dian Pratiwi, S.Kep',
    role: 'Perawat Klinis di RSUD',
    text: 'KamusNers benar-benar mengubah cara saya belajar! Materinya sangat aplikatif dan instrukturnya responsif. Berhasil lulus ujian kompetensi pertama kali!',
    avatar: 'DP',
    rating: 5,
  },
  {
    name: 'Ns. Ahmad Fauzi, S.Kep',
    role: 'Mahasiswa S1 Keperawatan',
    text: 'Kelas Medikal Bedah sangat lengkap dan terstruktur. Harganya terjangkau untuk kualitas sebagus ini. Highly recommended untuk semua calon Ners!',
    avatar: 'AF',
    rating: 5,
  },
  {
    name: 'Ns. Risa Amalia, S.Kep',
    role: 'Perawat ICU',
    text: 'Saya sudah coba banyak platform belajar, tapi KamusNers yang paling relevan dengan kondisi klinis Indonesia. Materi KGD-nya luar biasa detail!',
    avatar: 'RA',
    rating: 5,
  },
];

const stats = [
  { value: '5.000+', label: 'Siswa Aktif' },
  { value: '15+', label: 'Kelas Tersedia' },
  { value: '98%', label: 'Kepuasan Siswa' },
  { value: '50+', label: 'Instruktur Ahli' },
];
---

<BaseLayout
  title="KamusNers - Platform Kelas Online Premium untuk Perawat"
  description="Platform belajar online terpercaya untuk perawat Indonesia. Kuasai kompetensi keperawatan medikal bedah, KGD, maternitas, dan lainnya bersama instruktur profesional."
>
  <Navbar slot="navbar" />
  <Footer slot="footer" />
  <WhatsAppButton slot="fab" />

  <!-- ── HERO ── -->
  <section class="relative min-h-screen flex items-center overflow-hidden pt-20" style="background: radial-gradient(ellipse at 70% 30%, rgba(13,148,136,0.25) 0%, transparent 60%), radial-gradient(ellipse at 20% 80%, rgba(94,234,212,0.15) 0%, transparent 50%), linear-gradient(135deg, #092c44 0%, #1e5f8a 55%, #0d6e66 100%);">
    <!-- Decorative circles -->
    <div class="absolute top-20 right-10 w-96 h-96 rounded-full bg-teal-500/10 blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-10 left-5 w-64 h-64 rounded-full bg-accent/10 blur-3xl pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-28 grid md:grid-cols-2 gap-12 items-center">
      <!-- Text -->
      <div>
        <div data-aos="fade-up" data-aos-delay="0">
          <span class="badge-teal mb-4 inline-block">🎓 Platform #1 untuk Ners Indonesia</span>
        </div>
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6"
          data-aos="fade-up"
          data-aos-delay="100"
        >
          Kuasai
          <span class="gradient-text">Kompetensi<br />Keperawatan</span>
          Anda
        </h1>
        <p
          class="text-white/70 text-lg leading-relaxed mb-8 max-w-lg"
          data-aos="fade-up"
          data-aos-delay="200"
        >
          KamusNers menghadirkan kelas online berkualitas tinggi yang dirancang khusus untuk perawat Indonesia. Belajar dari instruktur berpengalaman, kapan saja dan di mana saja.
        </p>
        <div
          class="flex flex-wrap gap-4"
          data-aos="fade-up"
          data-aos-delay="300"
        >
          <a href="/browse" class="btn-primary text-base px-8 py-3.5">
            Jelajahi Kelas
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M5 12h14m-7-7 7 7-7 7"/>
            </svg>
          </a>
          <a
            href="https://wa.me/6287896542511?text=Halo%20KamusNers%2C%20saya%20ingin%20tahu%20lebih%20tentang%20kelas%20yang%20tersedia"
            target="_blank"
            rel="noopener"
            class="btn-outline text-base px-8 py-3.5"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Konsultasi Gratis
          </a>
        </div>
      </div>

      <!-- Hero Visual -->
      <div class="relative flex items-center justify-center" data-aos="fade-left" data-aos-delay="200">
        <div class="relative w-full max-w-md mx-auto">
          <!-- Hero illustration image -->
          <img
            src="/hero.png"
            alt="Perawat profesional belajar online di KamusNers"
            class="w-full rounded-3xl shadow-[0_20px_60px_rgba(0,0,0,0.4)] object-cover animate-float"
            width="500"
            height="400"
            loading="eager"
          />
          <!-- Floating stat badge -->
          <div class="absolute -bottom-4 -right-4 glass rounded-2xl px-4 py-3 text-white text-center min-w-28">
            <div class="text-2xl font-extrabold text-accent">98%</div>
            <div class="text-xs text-white/60">Lulus Uji<br/>Kompetensi</div>
          </div>
          <!-- Floating avatar group -->
          <div class="absolute -top-4 -left-4 glass rounded-2xl px-3 py-2 flex items-center gap-2">
            <div class="flex -space-x-2">
              {['DP','AF','RA'].map(a => (
                <div class="w-7 h-7 rounded-full bg-gradient-to-br from-teal-400 to-primary-600 flex items-center justify-center text-white text-xs font-bold border-2 border-white/20">
                  {a[0]}
                </div>
              ))}
            </div>
            <span class="text-white text-xs font-medium">+5.000 siswa</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Wave bottom -->
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0 40C240 80 480 0 720 40C960 80 1200 0 1440 40V80H0V40Z" fill="white"/>
      </svg>
    </div>
  </section>

  <!-- ── STATS BAR ── -->
  <section class="py-10 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {stats.map((stat, i) => (
          <div
            class="text-center"
            data-aos="fade-up"
            data-aos-delay={i * 80}
          >
            <div class="text-3xl md:text-4xl font-extrabold text-primary-700">{stat.value}</div>
            <div class="text-sm text-gray-500 mt-1">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── FEATURES ── -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14" data-aos="fade-up">
        <h2 class="section-title">Kenapa Memilih <span class="gradient-text">KamusNers?</span></h2>
        <p class="section-subtitle">Platform yang dirancang spesifik untuk kebutuhan perawat Indonesia</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {features.map((f, i) => (
          <div
            class="bg-white rounded-2xl p-6 shadow-card hover:shadow-card-hover hover:-translate-y-1 transition-all duration-300 group"
            data-aos="fade-up"
            data-aos-delay={i * 80}
          >
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-teal-50 to-primary-50 flex items-center justify-center text-teal-600 mb-4 group-hover:bg-gradient-to-br group-hover:from-teal-500 group-hover:to-primary-600 group-hover:text-white transition-all duration-300">
              <Fragment set:html={f.icon} />
            </div>
            <h3 class="font-bold text-primary-800 mb-2">{f.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>

      <!-- Features bottom CTA -->
      <div class="text-center mt-14" data-aos="fade-up">
        <p class="text-gray-500 mb-5 text-lg">Siap meningkatkan kompetensi Anda? Pilih kelas yang tepat sekarang.</p>
        <div class="flex flex-wrap gap-4 justify-center">
          <a href="/browse"
            class="inline-flex items-center gap-2 font-bold px-8 py-4 rounded-xl text-white text-base transition-all duration-300 hover:-translate-y-0.5 hover:opacity-90 active:scale-95"
            style="background: linear-gradient(135deg, #0d9488 0%, #1e5f8a 100%); box-shadow: 0 4px 24px rgba(13,148,136,0.4);"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            Lihat Semua Kelas
          </a>
          <a href="https://wa.me/6287896542511?text=Halo%20KamusNers%2C%20saya%20ingin%20tahu%20lebih%20lanjut" target="_blank" rel="noopener" class="inline-flex items-center gap-2 font-semibold px-8 py-4 rounded-xl border-2 border-primary-600 text-primary-700 hover:bg-primary-600 hover:text-white transition-all duration-300 active:scale-95 text-base">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Konsultasi Gratis
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FEATURED COURSES ── -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14" data-aos="fade-up">
        <h2 class="section-title">Kelas <span class="gradient-text">Unggulan</span></h2>
        <p class="section-subtitle">Pilih kelas yang sesuai kebutuhan karir keperawatan Anda</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-7">
        {featuredCourses.map((course, i) => (
          <div data-aos="fade-up" data-aos-delay={i * 100} class="h-full">
            <CourseCard {...course} />
          </div>
        ))}
      </div>
      <div class="text-center mt-12" data-aos="fade-up">
        <a href="/browse" class="btn-primary-dark text-base px-8 py-3.5">
          Lihat Semua Kelas
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M5 12h14m-7-7 7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ── TESTIMONIALS ── -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14" data-aos="fade-up">
        <h2 class="section-title">Kata Mereka <span class="gradient-text">Tentang KamusNers</span></h2>
        <p class="section-subtitle">Bergabung bersama ribuan perawat yang sudah merasakan manfaatnya</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {testimonials.map((t, i) => (
          <div
            class="testimonial-card"
            data-aos="fade-up"
            data-aos-delay={i * 100}
          >
            <!-- Stars -->
            <div class="flex gap-1 mb-4">
              {Array.from({ length: t.rating }).map(() => (
                <svg class="w-4 h-4 text-yellow-400" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              ))}
            </div>
            <p class="text-gray-600 text-sm leading-relaxed mb-5 italic">"{t.text}"</p>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-gradient-to-br from-teal-400 to-primary-600 flex items-center justify-center text-white text-sm font-bold">
                {t.avatar}
              </div>
              <div>
                <div class="font-bold text-primary-800 text-sm">{t.name}</div>
                <div class="text-gray-400 text-xs">{t.role}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA BANNER ── -->
  <section class="py-20 relative overflow-hidden" style="background: radial-gradient(ellipse at 70% 30%, rgba(13,148,136,0.25) 0%, transparent 60%), linear-gradient(135deg, #092c44 0%, #1e5f8a 55%, #0d6e66 100%);">
    <div class="absolute inset-0 bg-gradient-to-r from-primary-900/80 to-teal-900/80"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center" data-aos="fade-up">
      <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-4">
        Siap Tingkatkan Kompetensi Anda?
      </h2>
      <p class="text-white/70 text-lg mb-8">
        Mulai perjalanan belajar Anda hari ini. Akses kelas, komunitas, dan sertifikat — semua dalam satu platform.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="/browse" class="btn-primary text-base px-8 py-4">
          Mulai Belajar Sekarang
        </a>
        <a
          href="https://wa.me/6287896542511?text=Halo%20KamusNers%2C%20saya%20ingin%20bergabung!"
          target="_blank"
          rel="noopener"
          class="btn-outline text-base px-8 py-4"
        >
          Tanya via WhatsApp
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
