---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

export const prerender = true;

const faqs = [
  {
    q: 'Bagaimana cara mengakses kelas yang sudah dibeli?',
    a: 'Setelah pembayaran berhasil, Anda akan mendapat email konfirmasi dari Mayar. Login ke Customer Portal Mayar menggunakan email yang Anda daftarkan untuk mengakses semua kelas Anda.',
  },
  {
    q: 'Berapa lama akses kelas berlaku?',
    a: 'Akses kelas berlaku seumur hidup (lifetime access). Anda bisa belajar kapan saja dan mengulang materi sebanyak yang Anda mau.',
  },
  {
    q: 'Bagaimana mendapatkan sertifikat?',
    a: 'Sertifikat digital akan otomatis tersedia setelah Anda menyelesaikan semua modul dan lulus kuis akhir dengan nilai minimal 70.',
  },
  {
    q: 'Apa yang harus dilakukan jika lupa password?',
    a: 'Gunakan fitur "Lupa Password" di halaman login Mayar. Email reset password akan dikirim ke alamat email yang terdaftar.',
  },
];
---

<BaseLayout
  title="My Account - KamusNers"
  description="Akses akun dan kelas online KamusNers Anda melalui Mayar Customer Portal."
>
  <Navbar slot="navbar" />
  <Footer slot="footer" />
  <WhatsAppButton slot="fab" />

  <!-- Page Header -->
  <section class="bg-primary-900 pt-28 pb-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-teal-400 to-primary-600 flex items-center justify-center mx-auto mb-6 shadow-glow-teal" data-aos="fade-up">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
          <circle cx="12" cy="7" r="4"/>
        </svg>
      </div>
      <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4" data-aos="fade-up" data-aos-delay="100">
        <span class="gradient-text">My Account</span>
      </h1>
      <p class="text-white/60 text-lg" data-aos="fade-up" data-aos-delay="200">
        Akses semua kelas dan sertifikat Anda melalui Mayar Customer Portal.
      </p>
    </div>
  </section>

  <!-- Portal Access -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Main Card - Premium gradient border -->
      <div class="relative mb-12" data-aos="fade-up">
        <!-- Glow border effect -->
        <div class="absolute -inset-0.5 bg-gradient-to-r from-teal-400 via-primary-500 to-teal-600 rounded-3xl blur opacity-40"></div>
        <div class="relative bg-white rounded-3xl shadow-card p-8 md:p-12 text-center">
          <!-- Live badge -->
          <div class="inline-flex items-center gap-2 bg-green-50 text-green-700 text-xs font-bold px-3 py-1.5 rounded-full mb-6 border border-green-200">
            <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
            Portal Aktif 24/7
          </div>
          <div class="text-6xl mb-5">🎓</div>
          <h2 class="text-2xl md:text-3xl font-extrabold text-primary-800 mb-3">
            Akses Portal Siswa Anda
          </h2>
          <p class="text-gray-500 text-lg leading-relaxed mb-2 max-w-lg mx-auto">
            Semua kelas, materi, progress belajar, dan sertifikat tersimpan di Mayar Customer Portal.
          </p>
          <p class="text-gray-400 text-sm mb-8">Login menggunakan email yang Anda gunakan saat pembelian.</p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a
              href="https://mayar.id/customer"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 font-bold px-8 py-4 rounded-xl text-white text-base transition-all duration-300 hover:-translate-y-0.5 hover:opacity-90 active:scale-95"
              style="background: linear-gradient(135deg, #0d9488 0%, #1e5f8a 100%); box-shadow: 0 4px 24px rgba(13,148,136,0.4);"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                <polyline points="15 3 21 3 21 9"/>
                <line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
              Masuk ke Portal Mayar
            </a>
            <a href="/browse" class="inline-flex items-center justify-center gap-2 font-semibold px-8 py-4 rounded-xl border-2 border-primary-600 text-primary-700 hover:bg-primary-600 hover:text-white transition-all duration-300 active:scale-95 text-base">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
              </svg>
              Browse Kelas
            </a>
          </div>
        </div>
      </div>

      <!-- Steps -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16" data-aos="fade-up">
        {[
          { step: '1', icon: '💳', title: 'Beli Kelas', desc: 'Pilih kelas di halaman Browse dan selesaikan pembayaran via Mayar.' },
          { step: '2', icon: '📧', title: 'Cek Email', desc: 'Email konfirmasi akan dikirim otomatis setelah pembayaran berhasil.' },
          { step: '3', icon: '🎓', title: 'Mulai Belajar', desc: 'Login ke Mayar Portal dan akses semua kelas Anda seumur hidup.' },
        ].map((s, i) => (
          <div class="bg-white rounded-2xl p-6 shadow-card text-center" data-aos="fade-up" data-aos-delay={i * 80}>
            <div class="w-10 h-10 rounded-full bg-primary-600 text-white font-extrabold flex items-center justify-center mx-auto mb-3 text-lg">
              {s.step}
            </div>
            <div class="text-3xl mb-3">{s.icon}</div>
            <h3 class="font-bold text-primary-800 mb-2">{s.title}</h3>
            <p class="text-gray-500 text-sm">{s.desc}</p>
          </div>
        ))}
      </div>

      <!-- FAQ -->
      <div data-aos="fade-up">
        <h2 class="text-2xl font-bold text-primary-800 mb-6 text-center">Pertanyaan Umum</h2>
        <div class="space-y-4" id="faq-list">
          {faqs.map((faq, i) => (
            <div class="bg-white rounded-2xl shadow-card overflow-hidden faq-item" data-index={i}>
              <button
                class="faq-trigger w-full text-left px-6 py-5 flex items-center justify-between font-semibold text-primary-800 hover:bg-primary-50 transition-colors"
                aria-expanded="false"
              >
                <span>{faq.q}</span>
                <svg class="faq-chevron w-5 h-5 text-teal-500 shrink-0 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="6 9 12 15 18 9"/>
                </svg>
              </button>
              <div class="faq-answer hidden px-6 pb-5 text-gray-500 text-sm leading-relaxed">
                {faq.a}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Need help -->
      <div class="text-center mt-12" data-aos="fade-up">
        <p class="text-gray-500 mb-4">Masih butuh bantuan?</p>
        <a
          href="https://wa.me/6287896542511?text=Halo%20KamusNers%2C%20saya%20butuh%20bantuan%20akses%20akun%20saya"
          target="_blank"
          rel="noopener"
          class="btn-primary"
        >
          Chat Admin via WhatsApp
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const triggers = document.querySelectorAll('.faq-trigger');
  triggers.forEach(btn => {
    btn.addEventListener('click', () => {
      const answer = btn.nextElementSibling as HTMLElement;
      const chevron = btn.querySelector('.faq-chevron') as HTMLElement;
      const isOpen = !answer.classList.contains('hidden');

      // Close all
      document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
      document.querySelectorAll('.faq-chevron').forEach(c => (c as HTMLElement).style.transform = '');
      document.querySelectorAll('.faq-trigger').forEach(b => b.setAttribute('aria-expanded', 'false'));

      // Toggle current
      if (!isOpen) {
        answer.classList.remove('hidden');
        chevron.style.transform = 'rotate(180deg)';
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
