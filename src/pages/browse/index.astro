const categories = [
  { id: 'all', label: 'Semua Kelas' },
  { id: 'kritis', label: 'Keperawatan Kritis' },
  { id: 'maternitas', label: 'Maternitas' },
  { id: 'komunitas', label: 'Komunitas' },
  { id: 'dasar', label: 'Dasar' },
  { id: 'ujian', label: 'Persiapan Ujian' },
];
---

<BaseLayout
  title="Browse Kelas - KamusNers"
  description="Jelajahi semua kelas keperawatan di KamusNers. Dari Medikal Bedah, KGD, Maternitas, ICU, hingga persiapan UKMPPD Ners."
>
  <Navbar slot="navbar" />
  <Footer slot="footer" />
  <WhatsAppButton slot="fab" />

  <!-- Page Header -->
  <section class="bg-primary-900 pt-28 pb-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="badge-teal mb-4 inline-block" data-aos="fade-up">📚 Katalog Kelas</span>
      <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4" data-aos="fade-up" data-aos-delay="100">
        Browse <span class="gradient-text">Semua Kelas</span>
      </h1>
      <p class="text-white/60 text-lg max-w-xl mx-auto" data-aos="fade-up" data-aos-delay="200">
        {allCourses.length} kelas keperawatan premium tersedia, dirancang oleh instruktur berpengalaman.
      </p>
    </div>
  </section>

  <!-- Filter + Grid -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Category Filter -->
      <div class="flex flex-wrap gap-3 mb-10 justify-center" id="filter-buttons" data-aos="fade-up">
        {categories.map((cat) => (
          <button
            data-category={cat.id}
            class={`filter-btn px-5 py-2 rounded-full text-sm font-semibold border transition-all duration-200 ${cat.id === 'all' ? 'bg-primary-600 text-white border-primary-600' : 'bg-white text-gray-600 border-gray-200 hover:border-primary-400 hover:text-primary-600'}`}
          >
            {cat.label}
          </button>
        ))}
      </div>

      <!-- Course Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-7" id="course-grid">
        {allCourses.map((course, i) => (
          <div
            class="course-item h-full"
            data-category={course.category}
            data-aos="fade-up"
            data-aos-delay={Math.min(i * 60, 300)}
          >
            <CourseCard {...course} />
          </div>
        ))}
      </div>

      <!-- No results -->
      <div id="no-results" class="hidden text-center py-20">
        <div class="text-5xl mb-4">🔍</div>
        <p class="text-gray-400 text-lg">Tidak ada kelas dalam kategori ini.</p>
        <button data-category="all" class="filter-btn btn-primary-dark mt-6 py-2.5 px-6">Lihat Semua Kelas</button>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const filterButtons = document.querySelectorAll<HTMLElement>('.filter-btn');
    const courseItems = document.querySelectorAll<HTMLElement>('.course-item');
    const noResults = document.getElementById('no-results');

    filterButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const category = btn.dataset.category || 'all';

        // Update button styles
        filterButtons.forEach(b => {
          b.classList.remove('bg-primary-600', 'text-white', 'border-primary-600');
          b.classList.add('bg-white', 'text-gray-600', 'border-gray-200');
        });
        btn.classList.add('bg-primary-600', 'text-white', 'border-primary-600');
        btn.classList.remove('bg-white', 'text-gray-600', 'border-gray-200');

        // Filter items
        let visible = 0;
        courseItems.forEach(item => {
          const match = category === 'all' || item.dataset.category === category;
          item.style.display = match ? '' : 'none';
          if (match) visible++;
        });

        noResults?.classList.toggle('hidden', visible > 0);
      });
    });
  });
</script>
