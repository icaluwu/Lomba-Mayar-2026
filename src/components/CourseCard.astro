---
interface Props {
  title: string;
  description: string;
  price: string | number;
  originalPrice?: string | number;
  image?: string;
  checkoutUrl: string;
  badge?: string;
  badgeType?: 'popular' | 'new' | 'teal' | 'primary';
  duration?: string;
  level?: string;
  students?: string;
}

const {
  title,
  description,
  price,
  originalPrice,
  image,
  checkoutUrl,
  badge,
  badgeType = 'teal',
  duration = '8 minggu',
  level = 'Semua Level',
  students = '200+',
} = Astro.props;

const badgeClass =
  badgeType === 'popular'
    ? 'badge-popular'
    : badgeType === 'primary'
    ? 'badge-primary'
    : 'badge-teal';

const formattedPrice =
  typeof price === 'number'
    ? new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(price)
    : price;

const formattedOriginal =
  originalPrice && typeof originalPrice === 'number'
    ? new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(Number(originalPrice))
    : originalPrice;

// Calculate discount percentage
const discountPct =
  originalPrice && typeof price === 'number' && typeof originalPrice === 'number' && originalPrice > 0
    ? Math.round((1 - price / originalPrice) * 100)
    : null;
---

<article class="card group flex flex-col h-full relative">
  <!-- Thumbnail -->
  <div class="relative overflow-hidden aspect-[16/9] bg-gradient-to-br from-primary-700 to-teal-600">
    {image ? (
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    ) : (
      <!-- Gradient placeholder with icon -->
      <div class="absolute inset-0 flex items-center justify-center">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" class="opacity-30">
          <path d="M12 2L2 7l10 5 10-5-10-5zm0 7l-8 4 8 4 8-4-8-4zm0 7l-8 4 8 4 8-4-8-4z" fill="white"/>
        </svg>
      </div>
    )}

    <!-- Dark gradient overlay at bottom for badge readability -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent pointer-events-none"></div>

    <!-- Badge top-left -->
    {badge && (
      <div class="absolute top-3 left-3 z-10">
        <span class={`${badgeClass} shadow-lg`}>{badge}</span>
      </div>
    )}

    <!-- Discount badge top-right -->
    {discountPct && (
      <div class="absolute top-3 right-3 z-10">
        <span class="inline-flex items-center bg-red-500 text-white text-xs font-extrabold px-2.5 py-1 rounded-full shadow-lg tracking-wide">
          -{discountPct}%
        </span>
      </div>
    )}

    <!-- Level badge bottom-right -->
    <div class="absolute bottom-3 right-3 z-10">
      <span class="inline-flex items-center gap-1 bg-black/60 backdrop-blur-sm text-white text-xs font-semibold px-2.5 py-1 rounded-full">
        <svg class="w-3 h-3 text-teal-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
        </svg>
        {level}
      </span>
    </div>
  </div>

  <!-- Content -->
  <div class="flex flex-col flex-1 p-5">
    <h3 class="font-bold text-primary-800 text-lg leading-snug mb-2 group-hover:text-teal-600 transition-colors">
      {title}
    </h3>
    <p class="text-gray-500 text-sm leading-relaxed flex-1 mb-4">
      {description}
    </p>

    <!-- Meta chips -->
    <div class="flex items-center flex-wrap gap-2 mb-4">
      <span class="inline-flex items-center gap-1 bg-teal-50 text-teal-700 text-xs font-semibold px-2.5 py-1 rounded-full">
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
        </svg>
        {duration}
      </span>
      <span class="inline-flex items-center gap-1 bg-primary-50 text-primary-700 text-xs font-semibold px-2.5 py-1 rounded-full">
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
        </svg>
        {students} siswa
      </span>
    </div>

    <!-- Divider -->
    <div class="border-t border-gray-100 pt-4 mt-auto">
      <!-- Price row -->
      <div class="flex items-end justify-between mb-3">
        <div>
          <div class="text-2xl font-extrabold text-primary-700 leading-none">{formattedPrice}</div>
          {formattedOriginal && (
            <div class="text-xs text-gray-400 line-through mt-0.5">{formattedOriginal}</div>
          )}
        </div>
        {discountPct && (
          <div class="text-xs font-bold text-green-600 bg-green-50 px-2 py-1 rounded-lg">
            Hemat {discountPct}%
          </div>
        )}
      </div>

      <!-- Full-width CTA button -->
      <a
        href={checkoutUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="w-full inline-flex items-center justify-center gap-2 bg-gradient-to-r from-teal-500 to-primary-600 hover:from-teal-400 hover:to-primary-500 text-white font-bold py-3 px-4 rounded-xl transition-all duration-300 shadow-glow-teal hover:shadow-lg hover:-translate-y-0.5 active:scale-95 text-sm group/btn"
        aria-label={`Beli kelas ${title}`}
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        Daftar Sekarang
        <svg class="w-4 h-4 group-hover/btn:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M5 12h14m-7-7 7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</article>
