---
const navLinks = [
  { label: 'Home', href: '/', icon: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>` },
  { label: 'Browse', href: '/browse', icon: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>` },
  { label: 'About', href: '/about', icon: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>` },
  { label: 'Contact', href: '/contact', icon: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.18 2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.6a16 16 0 0 0 5.47 5.47l.95-.95a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21 16.92z"/></svg>` },
];

const currentPath = Astro.url.pathname;
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500"
>
  <!-- Top accent line -->
  <div class="h-0.5 bg-gradient-to-r from-teal-400 via-accent to-primary-400 w-full opacity-0 transition-opacity duration-500" id="navbar-accent"></div>

  <nav
    class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3 flex items-center justify-between gap-6"
  >
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group shrink-0" aria-label="KamusNers Home">
      <div class="relative">
        <img
          src="/logo.png"
          alt="KamusNers Logo"
          class="w-11 h-11 rounded-xl object-contain group-hover:scale-105 transition-transform duration-300 shadow-lg"
          style="background: rgba(255,255,255,0.1); padding: 2px;"
        />
        <!-- Online indicator -->
        <span class="absolute -bottom-0.5 -right-0.5 w-3 h-3 bg-teal-400 rounded-full border-2 border-primary-900 animate-pulse"></span>
      </div>
      <div class="flex flex-col leading-none">
        <span class="text-xl font-extrabold text-white tracking-tight">
          Kamus<span class="text-accent">Ners</span>
        </span>
        <span class="text-white/40 text-[9px] font-medium tracking-widest uppercase mt-0.5 hidden sm:block">Online Class untuk Perawat</span>
      </div>
    </a>

    <!-- Desktop Nav Links -->
    <ul class="hidden md:flex items-center gap-1">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class={`nav-link group flex items-center gap-1.5 px-3.5 py-2 rounded-lg text-sm font-semibold transition-all duration-200 ${
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-white bg-white/10'
                : 'text-white/70 hover:text-white hover:bg-white/10'
            }`}
          >
            <span class="opacity-60 group-hover:opacity-100 transition-opacity">
              <Fragment set:html={link.icon} />
            </span>
            {link.label}
            {(currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))) && (
              <span class="w-1 h-1 rounded-full bg-teal-400 ml-0.5"></span>
            )}
          </a>
        </li>
      ))}
    </ul>

    <!-- Right CTA area -->
    <div class="hidden md:flex items-center gap-3 shrink-0">
      <!-- WhatsApp quick contact -->
      <a
        href="https://wa.me/6287896542511?text=Halo%20KamusNers%21"
        target="_blank"
        rel="noopener"
        class="flex items-center gap-1.5 text-white/60 hover:text-green-400 transition-colors text-xs font-medium"
        aria-label="WhatsApp"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        <span class="hidden lg:block">Tanya Kami</span>
      </a>

      <!-- Divider -->
      <span class="w-px h-5 bg-white/20"></span>

      <!-- Browse CTA -->
      <a href="/browse"
        class="inline-flex items-center gap-1.5 text-sm font-semibold text-white rounded-lg px-4 py-2 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg active:scale-95"
        style="background: linear-gradient(135deg, #0d9488, #1e5f8a); box-shadow: 0 2px 12px rgba(13,148,136,0.35);"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M22 10v6M2 10l10-5 10 5-10 5-10-5z"/>
          <path d="M6 12v5c3 3 9 3 12 0v-5"/>
        </svg>
        Mulai Belajar
      </a>

      <!-- My Account -->
      <a href="/account" class="flex items-center gap-1.5 text-sm font-semibold text-white/80 hover:text-white border border-white/20 hover:border-white/40 rounded-lg px-4 py-2 transition-all duration-200 hover:bg-white/5">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
        </svg>
        My Account
      </a>
    </div>

    <!-- Mobile Hamburger -->
    <button
      id="hamburger"
      class="md:hidden flex flex-col gap-1.5 p-2 text-white rounded-lg hover:bg-white/10 transition-colors"
      aria-label="Toggle mobile menu"
      aria-expanded="false"
    >
      <span class="block w-6 h-0.5 bg-white transition-all duration-300" id="bar1"></span>
      <span class="block w-6 h-0.5 bg-white transition-all duration-300" id="bar2"></span>
      <span class="block w-4 h-0.5 bg-white transition-all duration-300" id="bar3"></span>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden glass mx-4 mb-2 rounded-2xl px-5 py-5 shadow-xl"
  >
    <!-- Mobile logo hint -->
    <div class="flex items-center gap-2 mb-4 pb-4 border-b border-white/10">
      <img src="/logo.png" alt="KamusNers" class="w-8 h-8 rounded-lg object-contain" />
      <div>
        <div class="text-white font-bold text-sm">KamusNers</div>
        <div class="text-white/40 text-[10px]">Online Class untuk Perawat</div>
      </div>
    </div>
    <ul class="flex flex-col gap-2">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class={`flex items-center gap-3 px-3 py-2.5 rounded-xl font-medium transition-all ${
              currentPath === link.href
                ? 'bg-teal-500/20 text-teal-300'
                : 'text-white/80 hover:text-white hover:bg-white/10'
            }`}
          >
            <span class="opacity-70"><Fragment set:html={link.icon} /></span>
            {link.label}
          </a>
        </li>
      ))}
      <li class="pt-2 border-t border-white/10">
        <a href="/browse"
          class="flex items-center justify-center gap-2 text-sm font-bold text-white rounded-xl py-3 w-full"
          style="background: linear-gradient(135deg, #0d9488, #1e5f8a);"
        >
          🎓 Mulai Belajar Sekarang
        </a>
      </li>
      <li>
        <a href="/account" class="flex items-center justify-center gap-2 btn-outline w-full text-sm py-2.5">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
          </svg>
          My Account
        </a>
      </li>
    </ul>
  </div>
</header>

<style>
  #navbar.scrolled {
    background: rgba(9, 44, 68, 0.95);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 2px 24px rgba(0,0,0,0.3);
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  #navbar.scrolled #navbar-accent {
    opacity: 1;
  }
  #navbar:not(.scrolled) {
    background: transparent;
  }
  /* Active nav underline override */
  .nav-link::after {
    display: none;
  }
</style>

<script>
  const navbar = document.getElementById('navbar');
  const navbarAccent = document.getElementById('navbar-accent');
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const bar3 = document.getElementById('bar3');

  // Scroll behavior
  function updateNavbar() {
    if (window.scrollY > 20) {
      navbar?.classList.add('scrolled');
    } else {
      navbar?.classList.remove('scrolled');
    }
  }

  window.addEventListener('scroll', updateNavbar);
  updateNavbar();

  // Add scrolled class for non-hero pages
  const isHeroPage = document.querySelector('[style*="radial-gradient"]');
  if (!isHeroPage) {
    navbar?.classList.add('scrolled');
  }

  // Mobile menu toggle
  let isOpen = false;
  hamburger?.addEventListener('click', () => {
    isOpen = !isOpen;
    hamburger.setAttribute('aria-expanded', String(isOpen));
    mobileMenu?.classList.toggle('hidden', !isOpen);
    // Animate bars
    if (isOpen) {
      bar1!.style.transform = 'rotate(45deg) translate(5px, 5px)';
      bar2!.style.opacity = '0';
      bar3!.style.transform = 'rotate(-45deg) translate(2px, -4px)';
      bar3!.style.width = '24px';
    } else {
      bar1!.style.transform = '';
      bar2!.style.opacity = '1';
      bar3!.style.transform = '';
      bar3!.style.width = '16px';
    }
  });
</script>
